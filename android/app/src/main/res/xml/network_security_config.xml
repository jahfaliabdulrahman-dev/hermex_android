<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Configuration — AUD-001 (MITM Protection)

  This file is the SINGLE SOURCE OF TRUTH for cleartext policy.
  android:usesCleartextTraffic was intentionally REMOVED from AndroidManifest.xml
  (Guardian C-5) to eliminate dual-permission redundancy. When both are set,
  networkSecurityConfig takes precedence, but the manifest attribute still
  appears in audit scans as a separate permission surface.

  DESIGN NOTE: Android's <domain> element does NOT support CIDR notation
  (e.g. 192.168.0.0/16). Instead of an exhaustive IP whitelist (which
  silently blocks any IP not listed — see LL-027), the base-config below
  permits cleartext to ALL destinations. Dart-level validation in
  ServerRepository._validateUrl() → isLocalNetwork() further restricts
  HTTP to RFC 1918 private IPs only.

  For release builds connecting to a LAN Hermes Agent server, HTTPS is
  strongly recommended. See app-spec/08_security_privacy.md §Network Security.
-->
<network-security-config xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      ── Local Network: permit cleartext (HTTP) to ANY private IP ──
      LL-027: domain-config whitelist with hardcoded IPs was removed.
      Android's <domain> element does NOT support CIDR (e.g. 192.168.0.0/16),
      so any IP not explicitly listed gets silently blocked. The base-config
      below now handles ALL destinations. Dart-level validation in
      ServerRepository._validateUrl() → isLocalNetwork() further restricts
      HTTP to RFC 1918 private IPs only.
    -->

    <!-- ── Default: permit cleartext for private IPs ── -->
    <!-- Dart-level validation (isLocalNetwork) already restricts HTTP to RFC 1918 only -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

</network-security-config>
